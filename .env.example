# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_for_seed_script

# Google OAuth (Gmail — same client as Supabase Google provider)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id
# Server-only: required for automatic token refresh (do NOT prefix with VITE_)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Groq API (for resume skill extraction)
GROQ_API_KEY=your_groq_api_key

# Razorpay Configuration (Test Mode)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# Razorpay Plan IDs (create in Dashboard > Subscriptions > Plans)
RAZORPAY_PLAN_ID_BASIC_MONTHLY=plan_xxxxx
RAZORPAY_PLAN_ID_BASIC_YEARLY=plan_xxxxx
RAZORPAY_PLAN_ID_PREMIUM_MONTHLY=plan_xxxxx
RAZORPAY_PLAN_ID_PREMIUM_YEARLY=plan_xxxxx
